# Maven Wrapper script - downloads and runs Apache Maven

set -e

MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_WRAPPERDIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"

# Read distribution URL from properties
if [ -f "$MAVEN_WRAPPERDIR/maven-wrapper.properties" ]; then
  distributionUrl="$(grep 'distributionUrl=' "$MAVEN_WRAPPERDIR/maven-wrapper.properties" | sed 's/distributionUrl=//' | tr -d '\r\n')"
fi
: "${distributionUrl:="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"}"

# Extract version from URL
MVN_VERSION="$(echo "$distributionUrl" | sed 's|.*apache-maven-\([0-9.]*\)-bin\.zip|\1|')"

# If mvn is already on PATH, use it
if command -v mvn > /dev/null 2>&1; then
  exec mvn "$@"
fi

# Determine java command
if [ -n "${JAVA_HOME-}" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
  if [ ! -x "$JAVA_CMD" ]; then
    echo "ERROR: JAVA_HOME is set to '$JAVA_HOME' but '$JAVA_CMD' is not executable." >&2
    exit 1
  fi
else
  JAVA_CMD="$(command -v java 2>/dev/null)" || true
  if [ ! -x "${JAVA_CMD-}" ]; then
    echo "ERROR: java not found in PATH and JAVA_HOME is not set." >&2
    exit 1
  fi
fi

# Install location
MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MVN_VERSION}"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  echo "Downloading Maven ${MVN_VERSION}..."
  echo "  from: $distributionUrl"

  TMP_DIR="$(mktemp -d)"
  trap 'rm -rf "$TMP_DIR"' EXIT INT TERM HUP

  TMP_ZIP="$TMP_DIR/maven.zip"

  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$TMP_ZIP" "$distributionUrl"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMP_ZIP" "$distributionUrl"
  else
    echo "ERROR: Neither curl nor wget found." >&2
    exit 1
  fi

  echo "  Extracting..."

  # Extract into TMP_DIR
  if command -v unzip > /dev/null 2>&1; then
    unzip -q -o "$TMP_ZIP" -d "$TMP_DIR"
  else
    (cd "$TMP_DIR" && "$JAVA_CMD" -Djava.io.tmpdir="$TMP_DIR" -cp "$TMP_ZIP" sun.tools.jar.Main xf "$TMP_ZIP" 2>/dev/null) || {
      echo "ERROR: Cannot extract (unzip not available)." >&2
      exit 1
    }
  fi

  # Find the extracted apache-maven-X.Y.Z directory
  EXTRACTED_DIR=""
  for d in "$TMP_DIR"/apache-maven-*; do
    if [ -d "$d" ]; then
      EXTRACTED_DIR="$d"
      break
    fi
  done

  if [ -z "$EXTRACTED_DIR" ] || [ ! -d "$EXTRACTED_DIR/bin" ]; then
    echo "ERROR: Extraction failed. Contents of temp dir:" >&2
    ls -la "$TMP_DIR" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$MAVEN_HOME")"
  rm -rf "$MAVEN_HOME"
  mv "$EXTRACTED_DIR" "$MAVEN_HOME"

  echo "  Maven installed to: $MAVEN_HOME"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"

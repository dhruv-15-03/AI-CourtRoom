# Copy this file to .env and fill in values for local development.
# .env is already in .gitignore and won't be committed.

# Database
DB_URL=jdbc:mysql://localhost:3306/ai_courtroom?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=your_mysql_username
DB_PASS=your_mysql_password

# Spring
PORT=8081
SHOW_SQL=false
DDL_AUTO=update

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:3000

# JWT Security (REQUIRED in production - use a strong random 64+ character string)
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_64_characters_long_here

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_MODEL=gemini-1.5-flash

# Razorpay Payment Gateway (Get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Email Configuration - Gmail SMTP (Get app password from https://myaccount.google.com/apppasswords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Firebase Configuration (Get from Firebase Console -> Project Settings -> Service Accounts)
# Option 1: Path to service account JSON file
FIREBASE_CREDENTIALS_PATH=
# Option 2: Entire JSON as a single line (escape quotes and newlines)
FIREBASE_CREDENTIALS_JSON=
